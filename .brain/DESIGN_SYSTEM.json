{
  "project_type": "game",
  "platform": "flutter",
  "colors": {
    "primary": "#00F5FF",
    "accent": "#FF00FF",
    "background": "#0D0D0D",
    "surface": "#1A1A2E",
    "text": "#FFFFFF",
    "success": "#00FF88",
    "warning": "#FFD700",
    "danger": "#FF3366",
    "grid_normal": "#1A1A3E",
    "grid_glow": "#00F5FF",
    "grid_charging": "#FF00FF"
  },
  "typography": {
    "font_family": "system-ui, -apple-system, sans-serif",
